# ---- Firebase (web SDK) ----
# Find these in Firebase Console → Project Settings → Your apps → SDK setup.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_APP_ID=

# ---- Backend API ----
# Local dev: leave as /api (Vite proxies to http://127.0.0.1:8000).
# Production (Vercel): set to the full Render URL, e.g.
#   VITE_API_BASE=https://teleleprosy-api.onrender.com
VITE_API_BASE=/api

# ---- Zoom Meeting SDK (browser) ----
VITE_ZOOM_SDK_KEY=
